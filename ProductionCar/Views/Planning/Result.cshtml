@{
    ViewData["Title"] = "Hasil Planning";
    var header = ViewBag.Header as ProductionCar.Models.PlanningHeader;
    var details = ViewBag.Details as List<ProductionCar.Models.PlanningDetail>;
}

<h2>Hasil Distribusi Produksi</h2>

<p><strong>Total Produksi:</strong> @header?.TotalProduction mobil</p>
<p><strong>Hari Aktif:</strong> @header?.TotalActiveDays hari</p>
@if (!string.IsNullOrEmpty(header?.Note))
{
    <p><strong>Catatan:</strong> @header.Note</p>
}

<table class="table table-bordered" style="max-width:600px">
    <thead class="table-dark">
        <tr>
            <th>Hari</th>
            <th>Planning Asep</th>
            <th>Hasil Perbaikan</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in details ?? new())
        {
            <tr class="@(d.IsHoliday ? "table-secondary" : "")">
                <td>@d.DayName</td>
                <td>@d.OriginalPlanning</td>
                <td>@(d.IsHoliday ? "-" : d.DistributedPlanning.ToString())</td>
                <td>@(d.IsHoliday ? "Libur" : "Aktif")</td>
            </tr>
        }
    </tbody>
</table>

<a href="/Planning" class="btn btn-secondary">Input Baru</a>
<a href="/Planning/History" class="btn btn-outline-primary">Lihat History</a>