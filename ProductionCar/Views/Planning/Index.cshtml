@{
    ViewData["Title"] = "Input Planning";
}

<h2>Input Rencana Produksi</h2>

<form method="post" action="/Planning/Calculate">
    <table class="table table-bordered" style="max-width:600px">
        <thead>
            <tr>
                <th>Hari</th>
                <th>Jumlah (0 = Libur)</th>
            </tr>
        </thead>
        <tbody>
            @{
                var days = new[] { "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu", "Minggu" };
                for (int i = 0; i < days.Length; i++)
                {
                    <tr>
                        <td>@days[i]</td>
                        <td><input type="number" name="dailyInput" min="0" value="0" class="form-control" /></td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <button type="submit" class="btn btn-primary">Hitung & Simpan</button>
</form>